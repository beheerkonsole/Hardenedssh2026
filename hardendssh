# ===============================
# Hardened OpenSSH Configuration
# Updated for OpenSSH 9.x (2026)
# Made by hansbalzak with AI
# AI is used for accuracy
# ===============================

########## NETWORK ##########

Port 22
AddressFamily inet
ListenAddress 0.0.0.0

# disable DNS lookups
UseDNS no

# hide version info when possible
DebianBanner no

########## AUTHENTICATION ##########

# disable root login
PermitRootLogin no

# only allow specific users (recommended)
#AllowUsers youruser

# disable password auth (key-only login)
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no

# enable key auth
PubkeyAuthentication yes

# disallow empty passwords
PermitEmptyPasswords no

# limit login attempts
MaxAuthTries 3
MaxSessions 2
LoginGraceTime 20

# rate limit connections
MaxStartups 3:50:10

########## ACCESS HARDENING ##########

# disable environment injection
PermitUserEnvironment no

# disable agent forwarding
AllowAgentForwarding no

# disable TCP forwarding
AllowTcpForwarding no

# disable unix socket forwarding
AllowStreamLocalForwarding no

# disable all forwarding
DisableForwarding yes

# disable tun devices
PermitTunnel no

# disable X11
X11Forwarding no

########## SESSION SECURITY ##########

# idle timeout
ClientAliveInterval 300
ClientAliveCountMax 2

# disable TCP keepalive
TCPKeepAlive no

# disable compression (security)
Compression no

########## CRYPTOGRAPHY ##########

# modern key exchange
KexAlgorithms sntrup761x25519-sha512@openssh.com,curve25519-sha256

# strong ciphers
Ciphers aes256-gcm@openssh.com,aes128-gcm@openssh.com

# strong MACs
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# modern host key algorithms
HostKeyAlgorithms ssh-ed25519

# host keys
HostKey /etc/ssh/ssh_host_ed25519_key

########## LOGGING ##########

LogLevel VERBOSE

########## SUBSYSTEM ##########

Subsystem sftp internal-sftp
